{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Standards Equivalents Schema",
  "description": "Schema for validation of API, ISO, GOST, and GB/T standard mappings.",
  "type": "array",
  "items": {
    "type": "object",
    "required": [
      "equipment",
      "equipment_ru",
      "api",
      "iso",
      "gost",
      "gbt",
      "scope",
      "scope_ru",
      "source",
      "revision",
      "verified_at"
    ],
    "properties": {
      "equipment": { "type": "string" },
      "equipment_ru": { "type": "string" },
      "api": { "type": "string" },
      "iso": { "type": "string" },
      "gost": { "type": "string" },
      "gbt": { "type": "string" },
      "scope": { "type": "string" },
      "scope_ru": { "type": "string" },
      "source": { "type": "string" },
      "revision": { "type": "string" },
      "verified_at": {
        "type": "string",
        "pattern": "^\\d{4}-\\d{2}$"
      }
    }
  }
}
